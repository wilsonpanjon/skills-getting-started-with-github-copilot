@page "/ecuador-provinces"

<PageTitle>Ecuador Provinces &amp; Population</PageTitle>

<div class="provinces-page">
    <section class="provinces-panel">
        <h1>Ecuador — Provinces &amp; Population</h1>
        <p class="provinces-intro">
            Ecuador is divided into <strong>24 provinces</strong>. The table below shows each province
            and its estimated population based on the 2022 national census.
        </p>

        <table class="provinces-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Province</th>
                    <th>Population (2022)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var (index, province) in Provinces.Select((p, i) => (i + 1, p)))
                {
                    <tr>
                        <td>@index</td>
                        <td>@province.Name</td>
                        <td class="population">@province.Population.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="2"><strong>Total</strong></td>
                    <td class="population"><strong>@Provinces.Sum(p => p.Population).ToString("N0")</strong></td>
                </tr>
            </tfoot>
        </table>
    </section>
</div>

@code {
    private record Province(string Name, int Population);

    private static readonly List<Province> Provinces =
