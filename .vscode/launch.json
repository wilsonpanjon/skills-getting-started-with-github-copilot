{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Mergington WebApp",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "src.app:app",
        "--reload",
        "--reload-include",
        "src/static/*"
      ],
      "jinja": true
    },
    {
      "name": "Launch Quadratic Equation Solver",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "${workspaceFolder}/QuadraticEquationSolver/bin/Debug/net10.0/QuadraticEquationSolver.dll",
      "cwd": "${workspaceFolder}/QuadraticEquationSolver",
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
